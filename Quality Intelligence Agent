<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quality Vision Agent Dashboard</title>
    <!-- Tailwind CSS for perfect layout replication -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons framework -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #0b1329; color: #f8fafc; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Header / Navigation -->
    <header class="bg-[#0f172a] border-b border-slate-800 px-6 py-4 flex items-center justify-between shadow-lg">
        <div class="flex items-center space-x-3">
            <div class="bg-blue-600 p-2 rounded-lg text-white">
                <i data-lucide="eye" class="w-6 h-6"></i>
            </div>
            <h1 class="text-xl font-bold tracking-tight">Quality Vision Agent</h1>
        </div>
        <nav class="hidden md:flex space-x-1" id="nav-tabs">
            <button onclick="switchTab('live-inspection')" id="btn-live-inspection" class="tab-btn bg-slate-800 text-blue-400 px-4 py-2 rounded-md font-medium text-sm transition">Live Inspection</button>
            <button onclick="switchTab('defect-library')" id="btn-defect-library" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition">Defect Library</button>
            <button onclick="switchTab('line-analytics')" id="btn-line-analytics" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition">Line Analytics</button>
            <button onclick="switchTab('model-intelligence')" id="btn-model-intelligence" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition">Model Intelligence</button>
            <button onclick="switchTab('executive-cockpit')" id="btn-executive-cockpit" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition flex items-center gap-1.5">
                Executive Cockpit <span class="bg-blue-500/20 text-blue-400 text-[10px] px-1.5 py-0.5 rounded font-bold uppercase tracking-wider">New</span>
            </button>
        </nav>
        <div class="flex items-center space-x-4">
            <span class="flex items-center text-xs bg-emerald-500/10 text-emerald-400 px-3 py-1 rounded-full border border-emerald-500/20 font-medium">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse mr-2"></span>
                Vision Live · 97fps
            </span>
        </div>
    </header>

    <!-- Content Wrap -->
    <main class="flex-1 p-6 max-w-[1600px] w-full mx-auto space-y-6">
        
        <!-- Controls & Filters -->
        <div class="flex flex-wrap items-center justify-between gap-4 bg-[#0f172a]/60 p-4 rounded-xl border border-slate-800">
            <div class="flex flex-wrap items-center gap-3">
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>All Plants</option></select>
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>All Shifts</option></select>
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>All Lines</option></select>
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>Today</option></select>
            </div>
            <div class="flex items-center gap-3">
                <button onclick="alert('Exporting Non-Conformance Reports (NCR)...')" class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-sm font-medium px-4 py-2 rounded-lg border border-slate-700 transition">
                    <i data-lucide="download" class="w-4 h-4"></i> Export NCRs
                </button>
                <button onclick="alert('Syncing with Manufacturing Execution System (MES)...')" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-sm font-medium px-4 py-2 rounded-lg transition shadow-md shadow-blue-600/20">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i> Sync MES
                </button>
            </div>
        </div>

        <!-- TAB 1: LIVE INSPECTION -->
        <div id="live-inspection" class="tab-content active space-y-6">
            
            <!-- Core Analytics Box -->
            <div class="bg-[#111c44] border border-slate-800 rounded-2xl p-6 shadow-xl relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1.5 h-full bg-blue-500"></div>
                <div class="mb-6">
                    <h2 class="text-xl font-bold tracking-wide text-white">Live Vision Inspection</h2>
                    <p class="text-xs text-slate-400 mt-1">Real-time defect detection and AI inference metrics · 8× Industrial Cameras</p>
                </div>

                <!-- Upper Deck Stats -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800/80">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Parts Inspected</p>
                        <p class="text-3xl font-extrabold text-white mt-1">1,284</p>
                        <span class="text-xs text-slate-500 block mt-1">Today · On-Pace</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800/80">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Pass Rate</p>
                        <p class="text-3xl font-extrabold text-emerald-400 mt-1">97.8%</p>
                        <span class="text-xs text-emerald-500 flex items-center mt-1">▲ 0.3pp Vs Target</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800/80">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Defects Found</p>
                        <p class="text-3xl font-extrabold text-amber-500 mt-1">28</p>
                        <span class="text-xs text-amber-500/80 block mt-1">41 Critical · Auto-Rejected</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800/80">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Escape Rate</p>
                        <p class="text-3xl font-extrabold text-blue-400 mt-1">0.4%</p>
                        <span class="text-xs text-emerald-500 flex items-center mt-1">▼ Target Achieved</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800/80">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Inference Time</p>
                        <p class="text-3xl font-extrabold text-blue-400 mt-1">8ms</p>
                        <span class="text-xs text-emerald-500 block mt-1">Under 10ms SLA</span>
                    </div>
                </div>

                <!-- Lower Extended Metrics Grid -->
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 pt-6 border-t border-slate-800/60 text-xs">
                    <div>
                        <span class="text-slate-400 font-medium block">Total Defects MTD</span>
                        <span class="text-xl font-bold text-white block mt-0.5">342</span>
                        <span class="text-[11px] text-emerald-400">Down 18% Vs Last Month</span>
                    </div>
                    <div>
                        <span class="text-slate-400 font-medium block">Critical MTD</span>
                        <span class="text-xl font-bold text-white block mt-0.5">41</span>
                        <span class="text-[11px] text-emerald-400">Down 60% Vs Baseline</span>
                    </div>
                    <div>
                        <span class="text-slate-400 font-medium block">Auto-Rejected</span>
                        <span class="text-xl font-bold text-white block mt-0.5">318</span>
                        <span class="text-[11px] text-blue-400">93% Auto · No Manual</span>
                    </div>
                    <div>
                        <span class="text-slate-400 font-medium block">Escaped Defects</span>
                        <span class="text-xl font-bold text-rose-400 block mt-0.5">5</span>
                        <span class="text-[11px] text-rose-400/80">0.4% Escape Rate</span>
                    </div>
                    <div>
                        <span class="text-slate-400 font-medium block">Open NCRs</span>
                        <span class="text-xl font-bold text-amber-400 block mt-0.5">47</span>
                        <span class="text-[11px] text-slate-500">Pending Review</span>
                    </div>
                    <div>
                        <span class="text-slate-400 font-medium block">Labour Hours Saved</span>
                        <span class="text-xl font-bold text-emerald-400 block mt-0.5">1,240h</span>
                        <span class="text-[11px] text-slate-500">MTD vs Baseline</span>
                    </div>
                </div>
            </div>

            <!-- Middle Split Matrix -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <!-- AI Quality Insights Hub -->
                <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-5 flex flex-col justify-between">
                    <div>
                        <div class="flex items-center justify-between border-b border-slate-800/60 pb-3 mb-4">
                            <div class="flex items-center space-x-2 text-blue-400">
                                <i data-lucide="sparkles" class="w-5 h-5"></i>
                                <h3 class="font-bold text-white text-base">AI Quality Insights</h3>
                            </div>
                            <span class="text-[10px] bg-blue-500/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded-full font-semibold">AI Generated</span>
                        </div>
                        <div class="space-y-3 max-h-[310px] overflow-y-auto pr-1">
                            <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 text-xs">
                                <p class="text-slate-300">Surface Crack rate on Line 3 is 2.4× above plant average — likely tooling wear on Station 7.</p>
                                <button onclick="alert('Analyzing tooling alignment metrics...')" class="mt-2 text-blue-400 hover:underline font-medium block">Inspect Tooling</button>
                            </div>
                            <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 text-xs">
                                <p class="text-slate-300">Line 5 camera (CAM-05B) offline — 86 uninspected parts in the last 2 hours. Manual check recommended.</p>
                                <button onclick="alert('Flagging uninspected batches...')" class="mt-2 text-blue-400 hover:underline font-medium block">Flag Parts</button>
                            </div>
                            <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 text-xs">
                                <p class="text-slate-300">Model confidence on Porosity class has dropped 4.2% this week — retraining recommended.</p>
                                <button onclick="alert('Initializing pipeline auto-retrain sequence...')" class="mt-2 text-blue-400 hover:underline font-medium block">Retrain Model</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Defect Type Distribution Progress Mix -->
                <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-5">
                    <h3 class="font-bold text-white text-base mb-4 flex items-center gap-2">
                        <i data-lucide="pie-chart" class="w-5 h-5 text-indigo-400"></i> Defect Breakdown Mix
                    </h3>
                    <div class="space-y-3 text-xs">
                        <div>
                            <div class="flex justify-between mb-1"><span class="text-slate-300">Surface Cracks</span><span class="font-semibold text-white">142 (41.5%)</span></div>
                            <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden"><div class="bg-blue-500 h-full rounded-full" style="width: 41.5%"></div></div>
                        </div>
                        <div>
                            <div class="flex justify-between mb-1"><span class="text-slate-300">Dim. Tolerance</span><span class="font-semibold text-white">88 (25.7%)</span></div>
                            <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden"><div class="bg-indigo-500 h-full rounded-full" style="width: 25.7%"></div></div>
                        </div>
                        <div>
                            <div class="flex justify-between mb-1"><span class="text-slate-300">Assembly Align</span><span class="font-semibold text-white">62 (18.1%)</span></div>
                            <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden"><div class="bg-amber-500 h-full rounded-full" style="width: 18.1%"></div></div>
                        </div>
                        <div>
                            <div class="flex justify-between mb-1"><span class="text-slate-300">Foreign Object</span><span class="font-semibold text-white">34 (9.9%)</span></div>
                            <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden"><div class="bg-purple-500 h-full rounded-full" style="width: 9.9%"></div></div>
                        </div>
                        <div>
                            <div class="flex justify-between mb-1"><span class="text-slate-300">Colour Variance</span><span class="font-semibold text-white">16 (4.7%)</span></div>
                            <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden"><div class="bg-pink-500 h-full rounded-full" style="width: 4.7%"></div></div>
                        </div>
                    </div>
                </div>

                <!-- Global Plant Performance Trackers -->
                <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-5">
                    <h3 class="font-bold text-white text-base mb-4 flex items-center gap-2">
                        <i data-lucide="globe" class="w-5 h-5 text-emerald-400"></i> Plant Performance Overview
                    </h3>
                    <div class="space-y-3">
                        <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 flex items-center justify-between">
                            <div>
                                <span class="text-sm font-bold block text-white">Bangalore, India</span>
                                <span class="text-[11px] text-slate-400">4,190 Inspected · 103 Defects</span>
                            </div>
                            <div class="text-right">
                                <span class="text-base font-extrabold text-emerald-400">97.6%</span>
                                <span class="text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold uppercase block mt-0.5">Good</span>
                            </div>
                        </div>
                        <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 flex items-center justify-between">
                            <div>
                                <span class="text-sm font-bold block text-white">Pune, India</span>
                                <span class="text-[11px] text-slate-400">3,850 Inspected · 135 Defects</span>
                            </div>
                            <div class="text-right">
                                <span class="text-base font-extrabold text-amber-400">96.5%</span>
                                <span class="text-[10px] bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2 py-0.5 rounded font-bold uppercase block mt-0.5">Warning</span>
                            </div>
                        </div>
                        <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 flex items-center justify-between">
                            <div>
                                <span class="text-sm font-bold block text-white">Shanghai, China</span>
                                <span class="text-[11px] text-slate-400">3,760 Inspected · 177 Defects</span>
                            </div>
                            <div class="text-right">
                                <span class="text-base font-extrabold text-rose-400">95.1%</span>
                                <span class="text-[10px] bg-rose-500/10 text-rose-400 border border-rose-500/20 px-2 py-0.5 rounded font-bold uppercase block mt-0.5">Critical</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Live Camera Streaming Matrices -->
            <div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold text-white text-base flex items-center gap-2">
                        <i data-lucide="video" class="w-5 h-5 text-blue-400"></i> Live Camera Feeds
                    </h3>
                    <span class="text-xs text-slate-400 font-medium">5 Of 6 Online</span>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(15,23,42,0.7), rgba(15,23,42,0.4)), url('https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=300&q=80')">
                        <div class="flex justify-between items-start"><span class="text-xs font-bold text-white">CAM-01A</span><span class="text-[9px] bg-emerald-500 text-slate-950 font-extrabold px-1.5 py-0.5 rounded">LIVE</span></div>
                        <div><span class="text-[11px] font-medium text-slate-200 block">Line 1</span><span class="text-[9px] text-slate-400 block">Bangalore, India</span></div>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(15,23,42,0.7), rgba(15,23,42,0.4)), url('https://images.unsplash.com/photo-1537462715879-360eeb61a0bc?auto=format&fit=crop&w=300&q=80')">
                        <div class="flex justify-between items-start"><span class="text-xs font-bold text-white">CAM-02A</span><span class="text-[9px] bg-emerald-500 text-slate-950 font-extrabold px-1.5 py-0.5 rounded">LIVE</span></div>
                        <div><span class="text-[11px] font-medium text-slate-200 block">Line 2</span><span class="text-[9px] text-slate-400 block">Pune, India</span></div>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(15,23,42,0.7), rgba(15,23,42,0.4)), url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&w=300&q=80')">
                        <div class="flex justify-between items-start"><span class="text-xs font-bold text-white">CAM-03B</span><span class="text-[9px] bg-emerald-500 text-slate-950 font-extrabold px-1.5 py-0.5 rounded">LIVE</span></div>
                        <div><span class="text-[11px] font-medium text-slate-200 block">Line 3</span><span class="text-[9px] text-slate-400 block">Shanghai, China</span></div>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(15,23,42,0.7), rgba(15,23,42,0.4)), url('https://images.unsplash.com/photo-1563770660941-20978e870e26?auto=format&fit=crop&w=300&q=80')">
                        <div class="flex justify-between items-start"><span class="text-xs font-bold text-white">CAM-04A</span><span class="text-[9px] bg-emerald-500 text-slate-950 font-extrabold px-1.5 py-0.5 rounded">LIVE</span></div>
                        <div><span class="text-[11px] font-medium text-slate-200 block">Line 4</span><span class="text-[9px] text-slate-400 block">Bangalore, India</span></div>
                    </div>
                    <div class="bg-slate-950 border border-rose-950/40 rounded-xl aspect-video p-3 flex flex-col justify-between relative">
                        <div class="absolute inset-0 bg-rose-950/10 flex items-center justify-center"><i data-lucide="video-off" class="w-6 h-6 text-rose-500/50"></i></div>
                        <div class="z-10 flex justify-between items-start"><span class="text-xs font-bold text-slate-400">CAM-05B</span><span class="text-[9px] bg-rose-500/20 text-rose-400 border border-rose-500/30 font-bold px-1.5 py-0.5 rounded">OFFLINE</span></div>
                        <div class="z-10"><span class="text-[11px] font-medium text-slate-400 block">Line 5</span><span class="text-[9px] text-slate-500 block">Pune, India</span></div>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(15,23,42,0.7), rgba(15,23,42,0.4)), url('https://images.unsplash.com/photo-1616401784845-180882ba9ba8?auto=format&fit=crop&w=300&q=80')">
                        <div class="flex justify-between items-start"><span class="text-xs font-bold text-white">CAM-06C</span><span class="text-[9px] bg-emerald-500 text-slate-950 font-extrabold px-1.5 py-0.5 rounded">LIVE</span></div>
                        <div><span class="text-[11px] font-medium text-slate-200 block">Line 6</span><span class="text-[9px] text-slate-400 block">Shanghai, China</span></div>
                    </div>
                </div>
            </div>

            <!-- Live Streaming Real-Time Feed Table Log -->
            <div class="bg-[#0f172a] border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
                <div class="p-5 border-b border-slate-800 flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <h3 class="font-bold text-white text-base">Live Defect Feed</h3>
                        <span id="log-count" class="text-xs bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-full font-medium border border-blue-500/20">50 Records</span>
                    </div>
                    <div class="flex items-center space-x-2 text-xs text-slate-400">
                        <span class="w-2 h-2 rounded-full bg-blue-500 animate-ping"></span>
                        <span>Auto-updating stream</span>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-900/80 text-xs font-semibold text-slate-400 border-b border-slate-800">
                                <th class="p-4">Time</th>
                                <th class="p-4">Defect Type</th>
                                <th class="p-4">Defect ID</th>
                                <th class="p-4">Plant</th>
                                <th class="p-4">Line</th>
                                <th class="p-4">Confidence</th>
                                <th class="p-4">Camera Used</th>
                                <th class="p-4">Status</th>
                                <th class="p-4">Shift</th>
                                <th class="p-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="defect-rows" class="text-xs divide-y divide-slate-800/60 text-slate-300">
                            <!-- Real App Dataset Seed Rows -->
                            <tr class="hover:bg-slate-900/40 transition">
                                <td class="p-4 font-medium text-slate-400">20:43</td>
                                <td class="p-4 font-semibold text-white">Surface Crack</td>
                                <td class="p-4 text-slate-500">DEF-8805</td>
                                <td class="p-4">Pune, India</td>
                                <td class="p-4">Line 2</td>
                                <td class="p-4 font-mono text-emerald-400">88.4%</td>
                                <td class="p-4 text-slate-400">CAM-02A</td>
                                <td class="p-4"><span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold text-[10px]">PASS</span></td>
                                <td class="p-4 text-slate-400">Shift C</td>
                                <td class="p-4 text-right space-x-2">
                                    <button onclick="actionItem('DEF-8805', 'Assigned')" class="text-blue-400 hover:underline">Assign</button>
                                    <button onclick="actionItem('DEF-8805', 'Escalated')" class="text-amber-400 hover:underline">Escalate</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-slate-900/40 transition">
                                <td class="p-4 font-medium text-slate-400">20:43</td>
                                <td class="p-4 font-semibold text-white">Porosity</td>
