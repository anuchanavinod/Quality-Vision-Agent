    <!-- Interactivity Engine Scripts -->
    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Single Page Tab Selector Router Logic
        function switchTab(tabId) {
            // Deactivate all visible layouts
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => content.classList.remove('active'));

            // Reset navigation selection appearance styles
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(btn => {
                btn.classList.remove('bg-slate-800', 'text-blue-400');
                btn.classList.add('text-slate-400', 'hover:text-white');
            });

            // Make designated tab layouts visible
            document.getElementById(tabId).classList.add('active');

            // Apply selected highlighting properties to matching link item
            const activeBtn = document.getElementById(`btn-${tabId}`);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-400', 'hover:text-white');
                activeBtn.classList.add('bg-slate-800', 'text-blue-400');
            }
        }

        // Action items event capture trigger handler
        function actionItem(id, action) {
            alert(`Record ${id} successfully flagged for transaction state: ${action}`);
        }

        // Live Periodic Data Defect Event Stream Simulator
        const types = ['Surface Crack', 'Porosity', 'Weld Flaw', 'Edge Chip', 'Foreign Object', 'Dimensional Variance'];
        const environments = [
            { plant: 'Bangalore, India', line: 'Line 1', cam: 'CAM-01A' },
            { plant: 'Pune, India', line: 'Line 2', cam: 'CAM-02A' },
            { plant: 'Shanghai, China', line: 'Line 3', cam: 'CAM-03B' },
            { plant: 'Bangalore, India', line: 'Line 4', cam: 'CAM-04A' },
            { plant: 'Shanghai, China', line: 'Line 6', cam: 'CAM-06C' }
        ];
        const statusFlags = ['PASS', 'HALT', 'REJECT'];
        const shifts = ['Shift A', 'Shift B', 'Shift C'];
        let recordCounter = 50;

        setInterval(() => {
            const rowBody = document.getElementById('defect-rows');
            const currentTime = new Date();
            const timeStr = currentTime.toTimeString().split(' ')[0].substring(0, 5);

            const type = types[Math.floor(Math.random() * types.length)];
            const env = environments[Math.floor(Math.random() * environments.length)];
            const status = statusFlags[Math.floor(Math.random() * statusFlags.length)];
            const shift = shifts[Math.floor(Math.random() * shifts.length)];
            const accuracy = (Math.random() * (99.5 - 76.0) + 76.0).toFixed(1);
            const generatedId = `DEF-${Math.floor(Math.random() * 100) + 8806}`;

            let badge = '';
            if (status === 'HALT') badge = `<span class="bg-rose-500/10 text-rose-400 border border-rose-500/20 px-2 py-0.5 rounded font-bold text-[10px]">HALT</span>`;
            else if (status === 'REJECT') badge = `<span class="bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2 py-0.5 rounded font-bold text-[10px]">REJECT</span>`;
            else badge = `<span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold text-[10px]">PASS</span>`;

            const scoreColor = accuracy > 90 ? 'text-emerald-400' : 'text-amber-400';

            const elementRow = document.createElement('tr');
            elementRow.className = "hover:bg-slate-900/40 transition";
            elementRow.innerHTML = `
                <td class="p-4 font-medium text-blue-400">${timeStr}</td>
                <td class="p-4 font-semibold text-white">${type}</td>
                <td class="p-4 text-slate-500">${generatedId}</td>
                <td class="p-4">${env.plant}</td>
                <td class="p-4">${env.line}</td>
                <td class="p-4 font-mono ${scoreColor}">${accuracy}%</td>
                <td class="p-4 text-slate-400">${env.cam}</td>
                <td class="p-4">${badge}</td>
                <td class="p-4 text-slate-400">${shift}</td>
                <td class="p-4 text-right space-x-2">
                    <button onclick="actionItem('${generatedId}', 'Assigned')" class="text-blue-400 hover:underline">Assign</button>
                    <button onclick="actionItem('${generatedId}', 'Escalated')" class="text-amber-400 hover:underline">Escalate</button>
                </td>
            `;

            rowBody.insertBefore(elementRow, rowBody.firstChild);

            if (rowBody.children.length > 10) {
                rowBody.removeChild(rowBody.lastChild);
            }

            recordCounter++;
            document.getElementById('log-count').innerText = `${recordCounter} Records`;
        }, 5000);
    </script>
