    <!-- UI Interaction Scripts -->
    <script>
        // Initialize Lucide SVG Icons
        lucide.createIcons();

        // Trigger function for real-time table buttons
        function actionItem(id, action) {
            alert(`Defect ${id} has been successfully ${action}.`);
        }

        // Live Feed simulation script to periodically inject real defects
        const defectTypes = ['Surface Crack', 'Foreign Object', 'Edge Chip', 'Coating Defect', 'Dimensional Variance'];
        const locations = [
            { plant: 'Bangalore, India', line: 'Line 1', cam: 'CAM-01A' },
            { plant: 'Pune, India', line: 'Line 2', cam: 'CAM-02A' },
            { plant: 'Shanghai, China', line: 'Line 3', cam: 'CAM-03B' }
        ];
        const statuses = ['REJECT', 'HALT', 'PASS'];
        let recordCounter = 45;

        setInterval(() => {
            const tableBody = document.getElementById('defect-rows');
            const now = new Date();
            const timeStr = now.toTimeString().split(' ')[0].substring(0, 5);
            
            const randomType = defectTypes[Math.floor(Math.random() * defectTypes.length)];
            const randomLoc = locations[Math.floor(Math.random() * locations.length)];
            const randomStatus = statuses[Math.floor(Math.random() * statuses.length)];
            const confidence = (Math.random() * (99.9 - 75.0) + 75.0).toFixed(1);
            const defectId = `DEF-${Math.floor(Math.random() * 1000) + 8800}`;
            
            let statusBadge = '';
            if (randomStatus === 'HALT') statusBadge = `<span class="bg-rose-500/10 text-rose-400 border border-rose-500/20 px-2 py-0.5 rounded font-bold text-[10px]">HALT</span>`;
            else if (randomStatus === 'REJECT') statusBadge = `<span class="bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2 py-0.5 rounded font-bold text-[10px]">REJECT</span>`;
            else statusBadge = `<span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold text-[10px]">PASS</span>`;

            const confidenceColor = confidence > 90 ? 'text-emerald-400' : 'text-amber-400';

            const newRow = document.createElement('tr');
            newRow.className = "hover:bg-slate-900/40 transition animate-fadeIn";
            newRow.innerHTML = `
                <td class="p-4 font-medium text-blue-400">${timeStr}</td>
                <td class="p-4 font-semibold text-white">${randomType}</td>
                <td class="p-4 text-slate-500">${defectId}</td>
                <td class="p-4">${randomLoc.plant}</td>
                <td class="p-4">${randomLoc.line}</td>
                <td class="p-4 font-mono ${confidenceColor}">${confidence}%</td>
                <td class="p-4 text-slate-400">${randomLoc.cam}</td>
                <td class="p-4">${statusBadge}</td>
                <td class="p-4 text-right space-x-2">
                    <button onclick="actionItem('${defectId}', 'Assigned')" class="text-blue-400 hover:underline font-medium">Assign</button>
                    <button onclick="actionItem('${defectId}', 'Escalated')" class="text-amber-400 hover:underline font-medium">Escalate</button>
                </td>
            `;
            
            tableBody.insertBefore(newRow, tableBody.firstChild);
            
            // Manage max view row ceiling
            if (tableBody.children.length > 8) {
                tableBody.removeChild(tableBody.lastChild);
            }

            recordCounter++;
            document.getElementById('log-count').innerText = `${recordCounter} Records`;
        }, 6000);
    </script>
</body>
