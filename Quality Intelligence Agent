<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quality Vision Agent Dashboard</title>
    <!-- Tailwind CSS for styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons for clean dashboard iconography -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #0b1329; color: #f8fafc; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Top Navigation Bar -->
    <header class="bg-[#0f172a] border-b border-slate-800 px-6 py-4 flex items-center justify-between shadow-lg">
        <div class="flex items-center space-x-3">
            <div class="bg-blue-600 p-2 rounded-lg text-white">
                <i data-lucide="eye" class="w-6 h-6"></i>
            </div>
            <h1 class="text-xl font-bold tracking-tight">Quality Vision Agent</h1>
        </div>
        <nav class="hidden md:flex space-x-1" id="nav-tabs">
            <button onclick="switchTab('live-inspection')" id="btn-live-inspection" class="tab-btn bg-slate-800 text-blue-400 px-4 py-2 rounded-md font-medium text-sm transition">Live Inspection</button>
            <button onclick="switchTab('defect-library')" id="btn-defect-library" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition">Defect Library</button>
            <button onclick="switchTab('line-analytics')" id="btn-line-analytics" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition">Line Analytics</button>
            <button onclick="switchTab('model-intelligence')" id="btn-model-intelligence" class="tab-btn text-slate-400 hover:text-white px-4 py-2 rounded-md font-medium text-sm transition">Model Intelligence</button>
        </nav>
        <div class="flex items-center space-x-4">
            <span class="flex items-center text-xs bg-emerald-500/10 text-emerald-400 px-3 py-1 rounded-full border border-emerald-500/20 font-medium">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse mr-2"></span>
                Vision Live · 97fps
            </span>
        </div>
    </header>

    <!-- Main Content Layout -->
    <main class="flex-1 p-6 max-w-[1600px] w-full mx-auto space-y-6">
        
        <!-- Controls & Filters Bar (Global) -->
        <div class="flex flex-wrap items-center justify-between gap-4 bg-[#0f172a]/60 p-4 rounded-xl border border-slate-800">
            <div class="flex flex-wrap items-center gap-3">
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>All Plants</option></select>
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>All Shifts</option></select>
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>All Lines</option></select>
                <select class="bg-slate-800 border border-slate-700 text-sm rounded-lg px-3 py-2 text-slate-300 focus:outline-none focus:border-blue-500"><option>Today</option></select>
            </div>
            <div class="flex items-center gap-3">
                <button onclick="alert('Exporting Non-Conformance Reports (NCR)...')" class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-sm font-medium px-4 py-2 rounded-lg border border-slate-700 transition">
                    <i data-lucide="download" class="w-4 h-4"></i> Export NCRs
                </button>
                <button onclick="alert('Syncing with Manufacturing Execution System (MES)...')" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-sm font-medium px-4 py-2 rounded-lg transition shadow-md shadow-blue-600/20">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i> Sync MES
                </button>
            </div>
        </div>

        <!-- TAB 1: LIVE INSPECTION -->
        <div id="live-inspection" class="tab-content active space-y-6">
            <div class="bg-[#111c44] border border-slate-800 rounded-2xl p-6 shadow-xl relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1.5 h-full bg-blue-500"></div>
                <div class="mb-6">
                    <h2 class="text-xl font-bold tracking-wide text-white">Live Vision Inspection</h2>
                    <p class="text-xs text-slate-400 mt-1">Real-time defect detection and AI inference metrics · 8× Industrial Cameras</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Parts Inspected</p>
                        <p class="text-3xl font-extrabold text-white mt-1">1,284</p>
                        <span class="text-xs text-slate-500 block mt-1">Today · On-Pace</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Pass Rate</p>
                        <p class="text-3xl font-extrabold text-emerald-400 mt-1">97.8%</p>
                        <span class="text-xs text-emerald-500 flex items-center mt-1">▲ 0.3pp Vs Target</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Defects Found</p>
                        <p class="text-3xl font-extrabold text-amber-500 mt-1">28</p>
                        <span class="text-xs text-amber-500/80 block mt-1">41 Critical · Auto-Rejected</span>
                    </div>
                    <div class="p-4 bg-slate-900/50 rounded-xl border border-slate-800">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Escape Rate</p>
                        <p class="text-3xl font-extrabold text-blue-400 mt-1">0.4%</p>
                        <span class="text-xs text-emerald-500 flex items-center mt-1">▼ Target Achieved</span>
                    </div>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 pt-6 border-t border-slate-800/60">
                    <div><span class="text-xs text-slate-400 block font-medium">Total Defects MTD</span><span class="text-xl font-bold text-white block mt-0.5">342</span></div>
                    <div><span class="text-xs text-slate-400 block font-medium">Critical MTD</span><span class="text-xl font-bold text-white block mt-0.5">41</span></div>
                    <div><span class="text-xs text-slate-400 block font-medium">Auto-Rejected</span><span class="text-xl font-bold text-white block mt-0.5">318</span></div>
                    <div><span class="text-xs text-slate-400 block font-medium">Escaped Defects</span><span class="text-xl font-bold text-rose-400 block mt-0.5">5</span></div>
                    <div><span class="text-xs text-slate-400 block font-medium">Open NCRs</span><span class="text-xl font-bold text-amber-400 block mt-0.5">47</span></div>
                    <div><span class="text-xs text-slate-400 block font-medium">Inference Time</span><span class="text-xl font-bold text-blue-400 block mt-0.5">8ms</span></div>
                </div>
            </div>

            <!-- Middle Split Panels -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-5 flex flex-col justify-between">
                    <div>
                        <div class="flex items-center space-x-2 text-blue-400 mb-4">
                            <i data-lucide="sparkles" class="w-5 h-5"></i>
                            <h3 class="font-bold text-white text-base">AI Quality Insights</h3>
                        </div>
                        <div class="space-y-3">
                            <div class="p-3 bg-amber-500/5 rounded-xl border border-amber-500/10 text-xs">
                                <span class="text-amber-400 font-semibold block mb-1">Tooling Wear Flag</span>
                                Surface Crack rate on Line 3 is 2.4× above plant average — likely tooling wear on Station 7.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-5">
                    <h3 class="font-bold text-white text-base mb-4 flex items-center gap-2"><i data-lucide="pie-chart" class="w-5 h-5 text-indigo-400"></i> Defect Mix</h3>
                    <div class="space-y-3.5 text-xs">
                        <div>Surface Cracks - 41.5%</div>
                        <div class="w-full bg-slate-800 h-2 rounded-full"><div class="bg-blue-500 h-full w-[41.5%] rounded-full"></div></div>
                    </div>
                </div>

                <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-5">
                    <h3 class="font-bold text-white text-base mb-4 flex items-center gap-2"><i data-lucide="globe" class="w-5 h-5 text-emerald-400"></i> Plant Status</h3>
                    <div class="p-3 bg-slate-900/60 rounded-xl border border-slate-800 text-sm text-slate-300">Bangalore, India — 97.6% Pass Rate</div>
                </div>
            </div>

            <!-- Live Camera Feeds Grid -->
            <div>
                <h3 class="font-bold text-white text-base mb-4 flex items-center gap-2"><i data-lucide="video" class="w-5 h-5 text-blue-400"></i> Live Camera Feeds</h3>
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=400&q=80')">
                        <span class="text-xs font-bold text-white">CAM-01A</span>
                        <span class="text-[10px] text-emerald-400 flex items-center"><span class="w-1.5 h-1.5 bg-emerald-400 rounded-full mr-1.5 animate-pulse"></span>Line 1</span>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl aspect-video p-3 flex flex-col justify-between relative bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1537462715879-360eeb61a0bc?auto=format&fit=crop&w=400&q=80')">
                        <span class="text-xs font-bold text-white">CAM-02A</span>
                        <span class="text-[10px] text-emerald-400 flex items-center"><span class="w-1.5 h-1.5 bg-emerald-400 rounded-full mr-1.5 animate-pulse"></span>Line 2</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 2: DEFECT LIBRARY -->
        <div id="defect-library" class="tab-content space-y-6">
            <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-2">Defect Taxonomy Library</h2>
                <p class="text-sm text-slate-400 mb-6">Master catalog of structural anomalies registered within the visual recognition model models.</p>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden p-4">
                        <div class="h-32 bg-slate-800 rounded-lg mb-3 flex items-center justify-center text-slate-600"><i data-lucide="activity" class="w-8 h-8"></i></div>
                        <h4 class="font-bold text-white">Surface Fracture / Crack</h4>
                        <p class="text-xs text-slate-400 mt-1">Micro structural stress fractures exceeding 0.2mm length specs.</p>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden p-4">
                        <div class="h-32 bg-slate-800 rounded-lg mb-3 flex items-center justify-center text-slate-600"><i data-lucide="box" class="w-8 h-8"></i></div>
                        <h4 class="font-bold text-white">Dimensional Variance</h4>
                        <p class="text-xs text-slate-400 mt-1">Edge margins drifting out of compliance tolerances on critical axes.</p>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden p-4">
                        <div class="h-32 bg-slate-800 rounded-lg mb-3 flex items-center justify-center text-slate-600"><i data-lucide="alert-triangle" class="w-8 h-8"></i></div>
                        <h4 class="font-bold text-white">Foreign Object Debris (FOD)</h4>
                        <p class="text-xs text-slate-400 mt-1">External particulates remaining trapped post assembly tooling injection.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 3: LINE ANALYTICS -->
        <div id="line-analytics" class="tab-content space-y-6">
            <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4">Production Line Analytical Deck</h2>
                <div class="p-8 border border-dashed border-slate-800 text-center rounded-xl text-slate-500">
                    <i data-lucide="bar-chart-3" class="w-12 h-12 mx-auto mb-3 text-slate-600"></i>
                    <p class="text-sm">Historical telemetry stream linked successfully. Select a timeline overview card above to map volumetric yield variables.</p>
                </div>
            </div>
        </div>

        <!-- TAB 4: MODEL INTELLIGENCE -->
        <div id="model-intelligence" class="tab-content space-y-6">
            <div class="bg-[#0f172a] border border-slate-800 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-2">Model Intelligence & Hyperparameters</h2>
                <p class="text-sm text-slate-400 mb-6">Manage inference network model deployment metrics and dataset validation distributions.</p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-800">
                        <span class="text-xs text-slate-400 block uppercase font-bold tracking-wider">Active Vision Core</span>
                        <div class="text-lg font-bold text-blue-400 mt-1">ResNet-Vision-v4.92</div>
                        <span class="text-[11px] text-slate-500 block mt-2">Deployed: 4 days ago via central Edge cluster storage.</span>
                    </div>
                    <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-800">
                        <span class="text-xs text-slate-400 block uppercase font-bold tracking-wider">Inference Target Score Threshold</span>
                        <div class="text-lg font-bold text-emerald-400 mt-1">94.5% Global Confidence</div>
                        <span class="text-[11px] text-slate-500 block mt-2">Adjust system variables inside deployment configurations.</span>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- UI Interactivity Scripts -->
    <script>
        // Initialize Lucide SVG Icons
        lucide.createIcons();

        // Dynamically Handle Single Page Tab Switching Logic
        function switchTab(tabId) {
            // Hide all tab views
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => content.classList.remove('active'));

            // Remove active styles from navigation choices
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(btn => {
                btn.classList.remove('bg-slate-800', 'text-blue-400');
                btn.classList.add('text-slate-400', 'hover:text-white');
            });

            // Reveal chosen target content layout container
            document.getElementById(tabId).classList.add('active');

            // Apply highlighting to matching activated dashboard link choice
            const activeBtn = document.getElementById(`btn-${tabId}`);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-400', 'hover:text-white');
                activeBtn.classList.add('bg-slate-800', 'text-blue-400');
            }
        }
    </script>
</body>
</html>
